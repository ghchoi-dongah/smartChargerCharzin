<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="800dp"
    android:layout_height="480dp"
    android:orientation="horizontal"
    android:background="@color/background"
    tools:context=".MainActivity">

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/frameTop"
        android:name="com.dongah.smartcharger.pages.HeaderFragment"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:tag="frameTop"
        tools:layout="@layout/fragment_header"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent" />

    <FrameLayout
        android:id="@+id/frameBody"
        android:layout_width="match_parent"
        android:layout_height="388dp"
        android:visibility="visible"
        app:layout_constraintTop_toBottomOf="@id/frameTop"
        app:layout_constraintStart_toStartOf="parent" />


    <FrameLayout
        android:id="@+id/frameFooter"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:background="@color/black"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" >

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/footer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            tools:ignore="DuplicateIds">
            <ImageView
                android:id="@+id/imgNetwork"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintHorizontal_bias="0.27"
                android:background="@drawable/nonetwork"
                android:layout_marginStart="20dp"
                android:importantForAccessibility="no"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"  />

            <TextView
                android:id="@+id/textViewVersionValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Ver-DEVW 1.0.0 | "
                android:textSize="18sp"
                android:textColor="@color/white"
                app:layout_constraintTop_toTopOf="@id/imgNetwork"
                app:layout_constraintStart_toEndOf="@id/imgNetwork"
                app:layout_constraintBottom_toBottomOf="@id/imgNetwork" />

            <TextView
                android:id="@+id/textViewTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2026-01-15 12:47:50"
                android:textSize="18sp"
                android:textColor="@color/white"
                app:layout_constraintTop_toTopOf="@id/imgNetwork"
                app:layout_constraintStart_toEndOf="@id/textViewVersionValue"
                app:layout_constraintBottom_toBottomOf="@id/imgNetwork" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>
</androidx.constraintlayout.widget.ConstraintLayout>