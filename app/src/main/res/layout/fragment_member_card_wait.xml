<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout  xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="800dp"
    android:layout_height="388dp"
    tools:context=".pages.MemberCardWaitFragment">

    <!-- TODO: Update blank fragment layout -->

    <TextView
        android:id="@+id/txtMemberWaiting"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/memberCardWaitMessage"
        android:textSize="36sp"
        android:gravity="center"
        android:layout_marginTop="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>


    <TextView
        android:id="@+id/txtCount"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="42sp"
        android:textColor="@color/btnGradientCenterColor"
        app:layout_constraintStart_toStartOf="@id/imageViewLoading"
        app:layout_constraintTop_toTopOf="@id/imageViewLoading"
        app:layout_constraintBottom_toBottomOf="@id/imageViewLoading"
        app:layout_constraintEnd_toEndOf="@id/imageViewLoading" />


    <ImageView
        android:id="@+id/imageViewLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/ani_loading"
        android:importantForAccessibility="no"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />




</androidx.constraintlayout.widget.ConstraintLayout >