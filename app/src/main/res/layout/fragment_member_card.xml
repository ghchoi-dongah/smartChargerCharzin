<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="800dp"
    android:layout_height="388dp"
    tools:context=".pages.MemberCardFragment">

    <!-- TODO: Update blank fragment layout -->
    <TextView
        android:id="@+id/txtMemberMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/memberCardMessage"
        android:textSize="36sp"
        android:gravity="center"
        android:layout_marginTop="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>


    <ImageView
        android:id="@+id/imgCardSpinner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:importantForAccessibility="no"
        android:src="@drawable/card_to_reader_background"
        android:layout_marginTop="-50dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtMemberMessage"
        app:layout_constraintBottom_toBottomOf="parent"/>


    <ImageView
        android:id="@+id/imgMemberCardTagging"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:importantForAccessibility="no"
        android:background="@drawable/membercardtagging"
        app:layout_constraintLeft_toLeftOf="@id/imgCardSpinner"
        app:layout_constraintTop_toTopOf="@id/imgCardSpinner" />


</androidx.constraintlayout.widget.ConstraintLayout>