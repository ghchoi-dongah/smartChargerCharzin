<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="800dp"
    android:layout_height="388dp"
    tools:context=".pages.ControlDebugFragment">

    <!-- TODO: Update blank fragment layout -->

    <ImageView
        android:id="@+id/imgRx"
        android:layout_width="400dp"
        android:layout_height="50dp"
        android:layout_marginTop="5dp"
        android:background="@drawable/img_rx_bar"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        tools:ignore="ContentDescription" />

    <ListView
        android:id="@+id/listRx"
        android:layout_width="395dp"
        android:layout_height="330dp"
        android:layout_marginStart="5dp"
        app:layout_constraintLeft_toLeftOf="@id/imgRx"
        app:layout_constraintTop_toBottomOf="@id/imgRx" />

    <ImageView
        android:id="@+id/imgTx"
        android:layout_width="400dp"
        android:layout_height="50dp"
        android:background="@drawable/img_tx_bar"
        app:layout_constraintLeft_toRightOf="@id/imgRx"
        app:layout_constraintTop_toTopOf="@id/imgRx"
        tools:ignore="ContentDescription" />

    <ListView
        android:id="@+id/listTx"
        android:layout_width="400dp"
        android:layout_height="330dp"
        app:layout_constraintLeft_toLeftOf="@id/imgTx"
        app:layout_constraintTop_toBottomOf="@id/imgTx" />

    <Button
        android:id="@+id/btnClose"
        android:layout_width="100dp"
        android:layout_height="50dp"
        android:text="@string/exitButton"
        android:textColor="#FF000000"
        app:backgroundTint="@null"
        android:textSize="19sp"
        android:layout_marginTop="5dp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/selector_default_btn"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>